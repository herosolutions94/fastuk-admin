<section id="dashbaord">
  <div class="contain-fluid">
    <div class="heading">
      <div class="text">
            <h5>Pending Earnings</h5>
          </div>
          </div>
    
          <div class="dashTable">
            <div class="inc_width" id="basic-1_wrapper">
              <table class="dataTable display" id="basic-1">
                <thead>
                  <tr class="table-scnd-row">
                    <th width="20%">
                      <p>#</p>
                    </th>
                    <!-- <th width="10%">
                            <p>User</p>
                        </th> -->

                    <th width="20%">
                      <p>Amount</p>
                    </th>
                    <th width="20%">
                      <p>Type</p>
                    </th>
                    <th width="20%">
                      <p>Status</p>
                    </th>
                    <th width="20%">
                      <p>Created Time</p>
                    </th>

                  </tr>
                </thead>
                <tbody>
                  <% if (earnings && earnings.length> 0) { %> <% earnings.forEach((earning, index)=> { %>
                      <tr class="bottom-cntnt" id="rider-<%= riderId %>">
                        <!-- <td>
                                  
                                    <div class="flex">
                                        <div class="image">
                                            <img src="<%= helpers.getImage(earning.mem_image) %>" alt="User Image" />
                                        </div>
                                        
                                    </div>
                                   
                                </td> -->

                        <!-- <td>
                                    <p>
                                        <%= earning.rider_name %>
                                    </p>
                                </td> -->
                        <td>
                          <p>
                            <a href="/admin/job-detail/<%= earning.order_id %>" target="_blank"
                              rel="noopener noreferrer">
                              <%= earning.order_id %>
                            </a>
                          </p>
                        </td>

                        <td>
                          <p>
                            <%= earning.amount %>
                          </p>
                        </td>

                        <td>
                          <p>
                            <%= earning.earning_type ? earning.earning_type : earning.type %>
                          </p>
                        </td>

                        <td>
                          <p>
                            <%- helpers.getEarningStatus(earning.status) %>
                          </p>
                        </td>

                        <td>
                          <p>
                            <%= helpers.convertUtcToUkFormat(earning.created_time) %>
                          </p>
                        </td>

                      </tr>

                      <% }) %>
                        <% } else { %>
                          <tr>
                            <td colspan="8">
                              <p>No earnings found.</p>
                            </td>
                          </tr>
                          <% } %>
                </tbody>
              </table>
            </div>

            <div class="d-flex justify-content-end mt-3">
  <div
    style="
      background: #f8f9fa;
      padding: 12px 20px;
      border-radius: 8px;
      border: 1px solid #e5e5e5;
      min-width: 250px;
      text-align: right;
    "
  >
    <h5 style="margin: 0; font-weight: 600;">
      Total Amount:
      <span style="color: #28a745;">
        £<%= total.toFixed(2) %>
      </span>
    </h5>
  </div>
</div>

          </div>
        </div>
        </section>


        