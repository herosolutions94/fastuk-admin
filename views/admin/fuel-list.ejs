<section id="dashbaord">
  <div class="contain-fluid">
    <div class="heading">
      <div class="text">
        <h3>Vehicle Fuel</h3>
        <ul>
          <!-- <li><a href="/admin/dashbaord">Home</a></li> -->
          <li><a href="/admin/dashboard">Dashboard</a></li>

          <!-- <li class="active"><a href="">Vehicles</a></li> -->
        </ul>
      </div>
      <div class="text text2">
        <a href="/admin/add-vehicle-fuel-form/<%= rider_id %>" class="webBtn mdBtn greenBtn"><i class="fa-light fa-plus"></i>Add New</a>
      </div>
    </div>
    <div class="dashTable">
      <table class="dataTable display" id="basic-1">
        <thead>
          <tr class="table-scnd-row blog-table">
            <th width="10%">
              <p>Sr#</p>
            </th>
            <th width="10%">
              <p>Litres</p>
            </th>
            <th width="10%">
              <p>Price Per Litre</p>
            </th>
            <th width="10%">
              <p>Status</p>
            </th>
            <th width="10%">
              <p>Action</p>
            </th>
          </tr>
        </thead>
        <tbody>
          <% if (vehicleFuels && vehicleFuels.length > 0) { %> <% vehicleFuels.forEach((fuel, index)=> { %>
              <tr class="bottom-cntnt" id="<%= rider_id %>">
                <td>
                  <p>
                    <%= index + 1 %>
                  </p>
                </td>
                <td>
                  <p>
                    <%= fuel.litres %>
                  </p>
                </td>
                <td>
                  <p>
                    <%= fuel.price_per_litre %>
                  </p>
                </td>
               
                <td>
                  <p>
                    <% if (fuel.status===1) { %>
                      <a href="#" class="status badge success">Active</a>
                      <% } else { %>
                        <a href="#" class="status badge warning">Inactive</a>
                        <% } %>
                  </p>
                </td>
                <td>
                  <div class="btn-group">
                    <button type="button" class="dropdown-toggle" data-toggle="dropdown">
                      <i class="fa fa-ellipsis-h"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-primary" role="menu">
                      <li>
                        <a href="/admin/fuel/edit/<%= fuel.id %>"><i class="fa fa-pencil"
                            aria-hidden="true"></i>Edit</a>
                      </li>
                      <li>
                        <a href="#" class="delete-item" data-id="<%= rider_id %>" data-row="vehicle"
                          data-url="/admin/admin-vehicles/delete/<%= rider_id %>">
                          <i class="fa fa-trash" aria-hidden="true"></i> Delete
                        </a>
                      </li>
                    </ul>
                  </div>
                </td>
              </tr>
              <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="8">
                      <p>No vehicles found.</p>
                    </td>
                  </tr>
                  <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>