<section id="dashbaord">
  <div class="contain-fluid">
    <div class="heading">
      <div class="text">
        <h3>Assigned Vehicle</h3>
      </div>
      <div class="text text2">
  <% if (!vehicles || vehicles.length === 0) { %>
    <a
      href="/admin/rider/vehicle/assign-vehicle-form/<%= rider_id %>"
      class="webBtn mdBtn greenBtn">
      <i class="fa-light fa-plus"></i> Add New
    </a>
  <% } %>
</div>
    </div>
    <div class="dashTable">
      <table class="dataTable display" id="basic-1">
        <thead>
          <tr class="table-scnd-row blog-table">
            <th width="10%">
              <p>Sr#</p>
            </th>

            <th width="20%">
              <p>Title</p>
            </th>

            <th width="20%">
              <p> Rent</p>
            </th>

            <th width="10%">
              <p>Action</p>
            </th>
          </tr>
        </thead>
        <tbody>
          <% if (vehicles && vehicles.length > 0) { %> <%
          vehicles.forEach((vehicle, index) => { %>
          <tr class="bottom-cntnt" id="vehicle-<%= vehicle.id %>">
            <td>
              <p><%= index + 1 %></p>
            </td>

            <td>
              <p><%= vehicle.title %></p>
            </td>

            <td>
              <p><%= vehicle.vehicle_rental_price %></p>
            </td>
            <td>
              <div class="btn-group">
                <button
                  type="button"
                  class="dropdown-toggle"
                  data-toggle="dropdown">
                  <i class="fa fa-ellipsis-h"></i>
                </button>
                <ul class="dropdown-menu dropdown-primary" role="menu">
                  <li>
                    <a
                      href="/admin/rider/vehicle/edit/<%= rider_id %>/<%= vehicle.id %>">
                      <i class="fa fa-pencil" aria-hidden="true"></i> Edit
                    </a>
                  </li>
                  <li>
                    <a
                      href="#"
                      class="delete-item"
                      data-id="<%= vehicle.id %>"
                      data-row="vehicle"
                      data-url="/admin/rider/vehicle/delete/<%= rider_id %>/<%= vehicle.id %>">
                      <i class="fa fa-trash" aria-hidden="true"></i> Delete
                    </a>
                  </li>
                </ul>
              </div>
            </td>
          </tr>
          <% }) %> <% } else { %>
          <tr>
            <td colspan="8"><p>No vehicles found.</p></td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>
