<section id="dashbaord">
  <div class="contain-fluid">
    <div class="heading">
      <div class="text">
        <h3>Dashboard</h3>
      </div>
    </div>
    <div class="grids">
      
      <div class="flex">
        
        <div class="col">
          <a href="/admin/riders" class="tile_link">
            <div class="inner">
              <div class="icon">
                <i class="fa fa-person"></i>
              </div>
              <h3>Total Riders</h3>
              <p><%= stats.riders %></p>
            </div>
          </a>
        </div>

        <div class="col">
          <a href="/admin/users" class="tile_link">
            <div class="inner">
              <div class="icon">
                <i class="fa fa-user"></i>
              </div>
              <h3>Total Users</h3>
              <p><%= stats.members %></p>
            </div>
          </a>
        </div>

        <div class="col">
          <a href="/admin/business-users" class="tile_link">
            <div class="inner">
              <div class="icon">
                <i class="fa fa-business-time"></i>
              </div>
              <h3>Total Business Users</h3>
              <p><%= stats.business %></p>
            </div>
          </a>
        </div>

        <div class="col">
          <a href="/admin/messages" class="tile_link">
            <div class="inner">
              <div class="icon">
                <i class="fa-light fa-comments"></i>
              </div>
              <h3>Total Messages</h3>
              <p><%= stats.messages %></p>
            </div>
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
