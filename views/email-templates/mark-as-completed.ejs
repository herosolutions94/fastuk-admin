<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Delivery Stage Update</title>
</head>
<body style="margin:0; padding:20px; background-color:#f4f4f4; font-family:Arial,sans-serif;">
  <div style="max-width:900px; margin:auto; background:white; padding:20px; border-radius:8px; border:1px solid #d4e0df;">
    
    <!-- Logo -->
    <div style="text-align:center;">
      <img src="<%= adminData.logo %>" style="width:100px;" />
    </div>

    <!-- Header -->
    <h2 style="color:#077eff; margin-top:30px;">
      Delivery Update 📍
    </h2>

    <p>
      Your rider has successfully completed one stage of your delivery.
    </p>

    <p>
      Your order is still in progress and will be completed once all stages are finished.
    </p>

    <!-- Booking Info -->
    <table style="width:100%; margin-top:20px; border:1px solid #ddd;">
      <tr>
        <td style="padding:12px; font-weight:bold;">Booking ID</td>
        <td style="padding:12px;"><%= order.booking_id %></td>
      </tr>
      <tr>
        <td style="padding:12px; font-weight:bold;">Completed Stage</td>
        <td style="padding:12px;">Stage <%= stage.id %></td>
      </tr>
      <tr>
        <td style="padding:12px; font-weight:bold;">Status</td>
        <td style="padding:12px;"><%= stage.status %></td>
      </tr>
    </table>

    <!-- Locations -->
    <table style="width:100%; margin-top:10px;">
      <tr>
        <td style="width:50%; padding:10px;">
          <strong>Pickup Location</strong><br />
          <%= order.source_address %>, <%= order.source_city %><br />
          <%= order.source_postcode %>
        </td>
        <td style="width:50%; padding:10px;">
          <strong>Drop-off Location</strong><br />
          <%= order.dest_address %>, <%= order.dest_city %><br />
          <%= order.dest_postcode %>
        </td>
      </tr>
    </table>

    <!-- Parcels -->
    <% if(order.parcels?.length > 0){ %>
    <table style="width:100%; margin-top:20px; border:1px solid #ddd;">
      <thead>
        <tr style="background:#077eff; color:white;">
          <th style="padding:12px;">Parcel</th>
          <th style="padding:12px;">Source</th>
          <th style="padding:12px;">Destination</th>
        </tr>
      </thead>
      <tbody>
        <% order.parcels.forEach(parcel => { %>
        <tr>
          <td style="padding:12px;"><%= parcel.parcel_number %></td>
          <td style="padding:12px;"><%= parcel.source_address %></td>
          <td style="padding:12px;"><%= parcel.destination_address %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>

    <!-- CTA -->
    <div style="text-align:center; margin-top:20px;">
      <p style="color:#555;">
        You can track your delivery progress anytime.
      </p>
      <a href="https://fastukcouriers.com/order-track?tracking_id=<%= order.tracking_id %>"
         style="background:#077eff; color:#fff; padding:10px 25px; text-decoration:none; border-radius:50px;">
         Track Order
      </a>
    </div>

  </div>
</body>
</html>