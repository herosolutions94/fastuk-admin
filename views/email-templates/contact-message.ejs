<!DOCTYPE html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact Message</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 20px;
      background-color: #f4f4f4;
      font-family: Arial, Helvetica, sans-serif;
    "
  >
    <div
      style="
        max-width: 900px;
        margin: auto;
        background: #ffffff;
        padding: 20px;
        border-radius: 8px;
        border: 1px solid #d4e0df;
      "
    >
      <!-- Logo -->
      <table style="width: 100%; text-align: center">
        <tr>
          <td>
            <img
              src="<%= adminData.logo %>"
              alt="Logo"
              style="width: 120px; margin-bottom: 20px"
            />
          </td>
        </tr>
      </table>

```
  <!-- Heading -->
  <h2 style="color: #ed1c24; font-weight: 600">
    <% if (emailType === 'admin') { %>
      New Contact Message
    <% } else { %>
      Thank You for Contacting Us
    <% } %>
  </h2>

  <!-- Intro -->
  <p>
    <% if (emailType === 'admin') { %>
      You have received a new message from the website contact form.
    <% } else { %>
      Hi <strong><%= messageData.name %></strong>,<br /><br />
      Thank you for reaching out to us. We’ve received your message and our
      team will get back to you shortly.
    <% } %>
  </p>

  <!-- Details Table (Admin Only) -->
  <% if (emailType === 'admin') { %>
  <table
    style="
      width: 100%;
      margin-top: 20px;
      border-collapse: collapse;
      border: 1px solid #ddd;
    "
  >
    <tbody>
      <tr>
        <td style="padding: 12px; font-weight: 600; width: 30%">Name</td>
        <td style="padding: 12px"><%= messageData.name %></td>
      </tr>
      <tr style="background-color: #fafafa">
        <td style="padding: 12px; font-weight: 600">Email</td>
        <td style="padding: 12px"><%= messageData.email %></td>
      </tr>
      <tr>
        <td style="padding: 12px; font-weight: 600">Phone</td>
        <td style="padding: 12px"><%= messageData.phone_number %></td>
      </tr>
      <tr style="background-color: #fafafa">
        <td style="padding: 12px; font-weight: 600">Subject</td>
        <td style="padding: 12px"><%= messageData.subject %></td>
      </tr>
      <tr>
        <td style="padding: 12px; font-weight: 600">Date</td>
        <td style="padding: 12px">
          <%= helpers.formatUKDate(messageData?.created_date) %>
        </td>
      </tr>
    </tbody>
  </table>
  <% } %>

  <!-- Message Box (Both) -->
  <table
    style="
      width: 100%;
      margin-top: 20px;
      border-collapse: collapse;
      border: 1px solid #ddd;
    "
  >
    <thead>
      <tr style="background-color: #ed1c24; color: white">
        <th style="padding: 12px; text-align: left">
          Your Message
        </th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td style="padding: 15px; line-height: 1.6">
          <%= messageData.message %>
        </td>
      </tr>
    </tbody>
  </table>

  <!-- Footer -->
  <p style="margin-top: 30px; font-size: 13px; color: #777; text-align: center">
    <% if (emailType === 'admin') { %>
      This email was generated from the website contact form.
    <% } else { %>
      Please do not reply to this email. Our team will contact you soon.
    <% } %>
  </p>
</div>
```

  </body>
</html>
